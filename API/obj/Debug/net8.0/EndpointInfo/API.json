{
  "openapi": "3.0.1",
  "info": {
    "title": "SISTEMA DE MINIMARKET",
    "description": "Documentación de los servicios para el sistema de minimarket",
    "contact": {
      "name": "José Salazar"
    },
    "version": "v1"
  },
  "paths": {
    "/api/Caja/{cajaId}/sesion-activa": {
      "get": {
        "tags": [
          "Caja"
        ],
        "parameters": [
          {
            "name": "cajaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Caja/abrir": {
      "post": {
        "tags": [
          "Caja"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AperturaCajaRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AperturaCajaRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AperturaCajaRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Caja/cerrar": {
      "post": {
        "tags": [
          "Caja"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CierreCajaRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CierreCajaRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CierreCajaRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Caja/calcular-vuelto": {
      "post": {
        "tags": [
          "Caja"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VueltoRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/VueltoRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/VueltoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Producto": {
      "get": {
        "tags": [
          "Producto"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Producto"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Producto"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Producto/paget/all": {
      "get": {
        "tags": [
          "Producto"
        ],
        "parameters": [
          {
            "name": "pagina",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "cantidad",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Producto/{id}": {
      "get": {
        "tags": [
          "Producto"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Producto"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AperturaCajaRequest": {
        "type": "object",
        "properties": {
          "cajaId": {
            "type": "integer",
            "format": "int32"
          },
          "usuarioAperturaId": {
            "type": "integer",
            "format": "int32"
          },
          "montoInicial": {
            "type": "number",
            "format": "double"
          },
          "observaciones": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CierreCajaRequest": {
        "type": "object",
        "properties": {
          "cajaSesionId": {
            "type": "integer",
            "format": "int32"
          },
          "usuarioCierreId": {
            "type": "integer",
            "format": "int32"
          },
          "montoCierre": {
            "type": "number",
            "format": "double"
          },
          "observaciones": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProductoRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "categoriaId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "codigoBarras": {
            "type": "string",
            "nullable": true
          },
          "codigoInterno": {
            "type": "string",
            "nullable": true
          },
          "nombre": {
            "type": "string",
            "nullable": true
          },
          "descripcion": {
            "type": "string",
            "nullable": true
          },
          "unidadMedida": {
            "type": "string",
            "nullable": true
          },
          "precioCompra": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "precioVenta": {
            "type": "number",
            "format": "double"
          },
          "precioMayoreo": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "permiteStockNegativo": {
            "type": "boolean",
            "nullable": true
          },
          "estado": {
            "type": "string",
            "nullable": true
          },
          "imagenUrl": {
            "type": "string",
            "nullable": true
          },
          "fechaCreacion": {
            "type": "string",
            "format": "date-time"
          },
          "fechaActualizacion": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "VueltoRequest": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number",
            "format": "double"
          },
          "montoRecibido": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Ingrese el token JWT. Ejemplo: Bearer {token}",
        "scheme": "Bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}